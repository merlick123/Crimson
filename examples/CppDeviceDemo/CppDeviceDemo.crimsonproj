{
  "version": 2,
  "groups": {
    "cpp": {
      "kind": "cpp",
      "sources": [
        "contracts/**/*.idl"
      ],
      "excludes": [],
      "output": "cpp",
      "host": {
        "kind": "cmake",
        "configuration": {
          "buildDirectory": "build"
        }
      },
      "configuration": {}
    }
  }
}
