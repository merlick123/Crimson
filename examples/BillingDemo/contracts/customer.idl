namespace Billing.Contracts {
    /// Describes a customer-facing service.
    interface CustomerService {
        /// Stable identifier for the service instance.
        readonly int64 service_id;

        /// Internal connection string used for topology wiring.
        internal string connection_string;

        /// Human readable display name.
        string display_name = "unknown";

        /// Finds a customer record.
        /// @param customer_id The customer identifier.
        /// @return The serialized customer payload.
        string get_customer(string customer_id);

        /// Updates a customer display name.
        /// @param customer_id The customer identifier.
        /// @param new_name The new display name.
        void update_name(string customer_id, string new_name);

        interface Request {
            /// Requested customer id.
            string customer_id;
        }
    }

    enum CustomerState : string {
        Active = "active",
        Suspended = "suspended",
        Closed = "closed"
    }
}
