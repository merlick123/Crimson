{
  "version": 2,
  "groups": {
    "rust": {
      "kind": "rust",
      "sources": [
        "contracts/**/*.idl"
      ],
      "excludes": [],
      "output": "src",
      "host": {
        "kind": "cargo",
        "configuration": {}
      },
      "configuration": {
        "support": {
          "provider": "generated",
          "profile": "std"
        }
      }
    }
  }
}
