{
  "version": 2,
  "groups": {
    "csharp": {
      "kind": "csharp",
      "sources": [
        "contracts/**/*.idl"
      ],
      "excludes": [],
      "output": "src",
      "host": {
        "kind": "dotnet-msbuild",
        "configuration": {
          "projectDirectories": [
            "app"
          ]
        }
      },
      "configuration": {}
    }
  }
}
