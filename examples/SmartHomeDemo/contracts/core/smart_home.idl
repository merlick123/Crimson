namespace SmartHome {
    abstract interface Device {
        /// Stable identifier for the device.
        readonly string device_id;

        /// Human-friendly device name.
        string display_name;

        /// Reports the static capabilities supported by this device.
        set<DeviceFeature> get_supported_features();

        /// Describes the current device state.
        string describe_state();
    }

    abstract interface Camera : Device {
        /// Captures a short human-readable snapshot.
        string capture_snapshot();
    }

    abstract interface MotionSensor : Device {
        /// Indicates whether motion is currently detected.
        readonly bool motion_detected;
    }

    abstract interface Doorbell : Device {
        /// Rings or chimes the doorbell.
        void ring();
    }

    abstract interface Light : Device {
        /// Current brightness level.
        int32 brightness_percent = 0;

        /// Sets the light brightness level.
        /// @param value The requested brightness level.
        void set_brightness(int32 value);
    }

    abstract interface Thermostat : Device {
        /// Preferred temperature target.
        float64 target_temperature = 21;

        /// Reads the current measured temperature.
        float64 read_temperature();
    }

    abstract interface Speaker : Device {
        /// Plays or queues an announcement.
        /// @param message The message to speak.
        void play_announcement(string message);
    }

    abstract interface DeviceRegistry {
        /// Registers a device with the runtime.
        /// @param device The device instance to register.
        void register_device(Device device);

        /// Lists every registered device.
        list<Device> list_devices();

        /// Fetches a device by identifier.
        /// @param device_id The device identifier.
        Device get_device(string device_id);

        /// Finds all devices that advertise a specific capability.
        /// @param feature The feature to match.
        /// @return Matching devices.
        list<Device> find_devices(DeviceFeature feature);
    }

    abstract interface AutomationNetwork {
        /// Connects one device's automation output to another device.
        /// @param upstream_device_id The source device identifier.
        /// @param downstream_device_id The destination device identifier.
        void connect_devices(string upstream_device_id, string downstream_device_id);

        /// Traces an automation chain from a starting device.
        /// @param origin_device_id The starting device identifier.
        /// @return The ordered device chain.
        list<string> trace_chain(string origin_device_id);
    }

    interface SceneCommand {
        /// Scene name shown to users.
        string scene_name;

        /// Devices that should be targeted by the scene.
        list<string> target_device_ids;

        /// Whether the scene should arm away mode.
        bool away_mode_enabled;

        /// Brightness level for lighting devices.
        int32 brightness_percent = 35;

        /// Announcement to play on speaker-capable devices.
        string announcement = "Welcome home.";
    }

    interface DemoHomeRuntime : DeviceRegistry, AutomationNetwork {
        /// Human-friendly home name.
        string home_name = "unknown";

        /// Current active scene.
        string active_scene = "idle";

        /// Indicates whether the home is running in away mode.
        bool away_mode;

        /// Applies a scene across the selected devices.
        /// @param command The scene command.
        void apply_scene(SceneCommand command);
    }

    enum DeviceFeature {
        Camera,
        Motion,
        Doorbell,
        Lighting,
        Climate,
        Speaker,
        Automation
    }
}
